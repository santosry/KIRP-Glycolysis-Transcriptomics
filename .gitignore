# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# Output files from R documentation (pkgdown)
docs/reference/
docs/articles/
docs/news/
docs/authors.

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Manuscript files (NEVER publish on GitHub)
manuscrito*
*MANUSCRIPT*
manuscript/
!docs/MANUSCRIPT_VERSION_LOG.md
output/

# Private environment files
.env
.env.*

# Compressed data placeholders (actual data in .tsv)
data/raw/*.gz
